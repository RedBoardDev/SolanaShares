generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique // Discord user ID
  username  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wallet           UserWallet?
  deposits         Deposit[]
  withdrawRequests WithdrawRequest[]
  transactions     Transaction[]

  @@map("users")
}

model UserWallet {
  id           String @id @default(auto()) @map("_id") @db.ObjectId
  userId       String @unique
  walletAddress String @unique
  
  // Envelope encryption fields
  cipherSeed    String
  cipherDataKey String
  nonce         String
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("user_wallets")
}

model Deposit {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  depositId   String @unique
  userId      String
  signature   String @unique
  amount      Float
  slot        Int
  status      String // PENDING, CONFIRMED, FAILED
  createdAt   DateTime @default(now())
  processedAt DateTime?

  user User @relation(fields: [userId], references: [userId])

  @@map("deposits")
}

model WithdrawRequest {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  withdrawId  String @unique
  userId      String
  amount      Float
  status      String // PENDING, PROCESSING, DONE, FAILED
  signature   String?
  createdAt   DateTime @default(now())
  processedAt DateTime?

  user User @relation(fields: [userId], references: [userId])

  @@map("withdraw_requests")
}

model Snapshot {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  snapshotId String @unique
  timestamp  DateTime @default(now())
  
  // JSON storing user shares: { "userId1": 0.25, "userId2": 0.75 }
  userShares Json
  
  totalBalance Float
  status       String // PENDING, COMPLETED, FAILED

  @@map("snapshots")
}

model Transaction {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  txId        String @unique
  userId      String?
  signature   String @unique
  txType      String // SWEEP_IN, WITHDRAW, ADMIN_TRANSFER
  amount      Float
  status      String // PENDING, CONFIRMED, FAILED
  retryCount  Int    @default(0)
  errorMsg    String?
  createdAt   DateTime @default(now())
  confirmedAt DateTime?

  user User? @relation(fields: [userId], references: [userId])

  @@map("transactions")
}